---
interface Props {
  step: string;
  title: string;
  description: string;
}

const { step, title, description } = Astro.props;
---

<div class="text-center">
  <div
    class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-red-brand text-xl font-bold text-white"
  >
    {step}
  </div>
  <h3 class="mb-2 text-lg font-semibold text-text-primary">{title}</h3>
  <p class="text-sm leading-relaxed text-text-secondary">{description}</p>
</div>

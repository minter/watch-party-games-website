---
interface Props {
  name: string;
  tagline: string;
  icon: string;
  slug: string;
}

const { name, tagline, icon, slug } = Astro.props;
---

<a
  href={`/modules/${slug}`}
  class="group flex items-start gap-5 rounded-2xl border border-white/5 bg-surface-raised p-6 transition-all duration-300 hover:border-teal-500/30 hover:bg-surface-overlay hover:-translate-y-1"
>
  <div
    class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-teal-500/10 text-3xl transition-colors group-hover:bg-teal-500/20"
  >
    {icon}
  </div>
  <div class="min-w-0">
    <h3 class="mb-1 text-lg font-semibold text-text-primary">{name}</h3>
    <p class="text-sm leading-relaxed text-text-secondary">{tagline}</p>
    <span class="mt-2 inline-flex items-center gap-1 text-sm font-medium text-teal-400 opacity-0 transition-opacity group-hover:opacity-100">
      Learn more &rarr;
    </span>
  </div>
</a>

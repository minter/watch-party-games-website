---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="flex gap-4">
  <div
    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-brand/10 text-xl"
  >
    {icon}
  </div>
  <div>
    <h3 class="mb-1 font-semibold text-text-primary">{title}</h3>
    <p class="text-sm leading-relaxed text-text-secondary">{description}</p>
  </div>
</div>

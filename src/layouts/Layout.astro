---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Watch Party Games — Interactive Entertainment for NHL Watch Parties",
  description = "Turn your watch party into an unforgettable experience. 14+ interactive games designed for NHL arenas and fan events.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://watchparty.app" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>

---
import Layout from "../../layouts/Layout.astro";
import { games, getGameBySlug } from "../../data/games";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = () => {
  return games.map((game) => ({
    params: { slug: game.slug },
  }));
};

const { slug } = Astro.params;
const game = getGameBySlug(slug as string)!;

const currentIndex = games.findIndex((g) => g.slug === slug);
const prevGame = currentIndex > 0 ? games[currentIndex - 1] : null;
const nextGame =
  currentIndex < games.length - 1 ? games[currentIndex + 1] : null;

const categoryLabels: Record<string, string> = {
  trivia: "Trivia",
  competition: "Competition",
  physical: "Physical",
  social: "Social",
  utility: "Event Tool",
};

const categoryColors: Record<string, string> = {
  trivia: "bg-blue-500/10 text-blue-400 border-blue-500/20",
  competition: "bg-amber-500/10 text-amber-400 border-amber-500/20",
  physical: "bg-green-500/10 text-green-400 border-green-500/20",
  social: "bg-pink-500/10 text-pink-400 border-pink-500/20",
  utility: "bg-purple-500/10 text-purple-400 border-purple-500/20",
};
---

<Layout
  title={`${game.name} — Watch Party Games`}
  description={game.tagline}
>
  <!-- Nav -->
  <nav
    class="fixed top-0 z-50 w-full border-b border-white/5 bg-surface/80 backdrop-blur-xl"
  >
    <div
      class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4"
    >
      <a href="/" class="flex items-center gap-2 transition-colors hover:text-text-primary">
        <span class="text-xl font-bold text-text-primary">Watch Party Games</span>
      </a>
      <div class="hidden items-center gap-8 sm:flex">
        <a
          href="/#games"
          class="text-sm text-text-secondary transition-colors hover:text-text-primary"
          >All Games</a
        >
        <a
          href="/#how-it-works"
          class="text-sm text-text-secondary transition-colors hover:text-text-primary"
          >How It Works</a
        >
        <a
          href="/#features"
          class="text-sm text-text-secondary transition-colors hover:text-text-primary"
          >Features</a
        >
        <a
          href="/#contact"
          class="inline-flex items-center rounded-lg bg-red-brand px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-red-brand-dark"
          >Get Early Access</a
        >
      </div>
    </div>
  </nav>

  <main class="pt-28 pb-20 sm:pt-36 sm:pb-28">
    <div class="mx-auto max-w-4xl px-6">
      <!-- Breadcrumb -->
      <nav class="mb-8 flex items-center gap-2 text-sm text-text-muted">
        <a href="/" class="transition-colors hover:text-text-secondary">Home</a>
        <span>/</span>
        <a href="/#games" class="transition-colors hover:text-text-secondary">Games</a>
        <span>/</span>
        <span class="text-text-secondary">{game.name}</span>
      </nav>

      <!-- Header -->
      <div class="mb-12">
        <div class="mb-4 flex flex-wrap items-center gap-3">
          <span class="text-5xl">{game.icon}</span>
          <div>
            <div class="mb-2 flex items-center gap-3">
              <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
                {game.name}
              </h1>
              <span
                class={`rounded-full border px-3 py-0.5 text-xs font-medium ${categoryColors[game.category]}`}
              >
                {categoryLabels[game.category]}
              </span>
            </div>
            <p class="text-lg text-text-secondary sm:text-xl">{game.tagline}</p>
          </div>
        </div>
      </div>

      <!-- Quick stats -->
      <div
        class="mb-12 grid grid-cols-2 gap-4 sm:grid-cols-2"
      >
        <div class="rounded-xl border border-white/5 bg-surface-raised p-5">
          <div class="mb-1 text-xs font-medium uppercase tracking-wider text-text-muted">
            Players
          </div>
          <div class="text-lg font-semibold text-text-primary">{game.playerCount}</div>
        </div>
        <div class="rounded-xl border border-white/5 bg-surface-raised p-5">
          <div class="mb-1 text-xs font-medium uppercase tracking-wider text-text-muted">
            Duration
          </div>
          <div class="text-lg font-semibold text-text-primary">{game.duration}</div>
        </div>
      </div>

      <!-- Description -->
      <section class="mb-12">
        <h2 class="mb-4 text-2xl font-bold">About this game</h2>
        <p class="text-lg leading-relaxed text-text-secondary">
          {game.description}
        </p>
      </section>

      <!-- How it works -->
      <section class="mb-12">
        <h2 class="mb-4 text-2xl font-bold">How it works</h2>
        <p class="text-lg leading-relaxed text-text-secondary">
          {game.howItWorks}
        </p>
      </section>

      <!-- Highlights -->
      <section class="mb-12">
        <h2 class="mb-4 text-2xl font-bold">Highlights</h2>
        <ul class="space-y-3">
          {game.highlights.map((item) => (
            <li class="flex items-start gap-3 text-text-secondary">
              <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-red-brand" />
              <span class="text-lg leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- CTA -->
      <section class="mb-16 rounded-2xl border border-white/5 bg-surface-raised p-8 text-center sm:p-12">
        <h2 class="mb-3 text-2xl font-bold">
          Want to see {game.name} in action?
        </h2>
        <p class="mb-6 text-text-secondary">
          Request a demo and we'll walk you through the full experience.
        </p>
        <a
          href="/#contact"
          class="inline-flex items-center rounded-xl bg-red-brand px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-red-brand/25 transition-all hover:bg-red-brand-dark hover:shadow-red-brand/40 hover:-translate-y-0.5"
          >Request a Demo</a
        >
      </section>

      <!-- Prev/Next navigation -->
      <nav class="flex items-stretch gap-4">
        {prevGame ? (
          <a
            href={`/games/${prevGame.slug}`}
            class="group flex flex-1 items-center gap-3 rounded-xl border border-white/5 bg-surface-raised p-5 transition-all hover:border-red-brand/20 hover:bg-surface-overlay"
          >
            <span class="text-xl text-text-muted transition-transform group-hover:-translate-x-1">&larr;</span>
            <div>
              <div class="text-xs text-text-muted">Previous</div>
              <div class="font-semibold text-text-primary">{prevGame.icon} {prevGame.name}</div>
            </div>
          </a>
        ) : (
          <div class="flex-1" />
        )}
        {nextGame ? (
          <a
            href={`/games/${nextGame.slug}`}
            class="group flex flex-1 items-center justify-end gap-3 rounded-xl border border-white/5 bg-surface-raised p-5 text-right transition-all hover:border-red-brand/20 hover:bg-surface-overlay"
          >
            <div>
              <div class="text-xs text-text-muted">Next</div>
              <div class="font-semibold text-text-primary">{nextGame.name} {nextGame.icon}</div>
            </div>
            <span class="text-xl text-text-muted transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
        ) : (
          <div class="flex-1" />
        )}
      </nav>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-white/5 py-8">
    <div
      class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 sm:flex-row"
    >
      <span class="text-sm text-text-muted"
        >&copy; {new Date().getFullYear()} Watch Party Games</span
      >
      <span class="text-sm text-text-muted">watchparty.app</span>
    </div>
  </footer>
</Layout>

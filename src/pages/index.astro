---
import Layout from "../layouts/Layout.astro";
import GameCard from "../components/GameCard.astro";
import FeatureItem from "../components/FeatureItem.astro";
import StepCard from "../components/StepCard.astro";
import ModuleCard from "../components/ModuleCard.astro";
import { games } from "../data/games";
import { modules } from "../data/modules";
---

<Layout>
  <!-- Nav -->
  <nav
    class="fixed top-0 z-50 w-full border-b border-white/5 bg-surface/80 backdrop-blur-xl"
  >
    <div
      class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4"
    >
      <div class="flex items-center gap-2">
        <span class="text-xl font-bold text-text-primary"
          >Watch Party Games</span
        >
      </div>
      <div class="hidden items-center gap-8 sm:flex">
        <a
          href="#games"
          class="text-sm text-text-secondary transition-colors hover:text-text-primary"
          >Games</a
        >
        <a
          href="#event-tools"
          class="text-sm text-text-secondary transition-colors hover:text-text-primary"
          >Event Tools</a
        >
        <a
          href="#features"
          class="text-sm text-text-secondary transition-colors hover:text-text-primary"
          >Features</a
        >
        <a
          href="#contact"
          class="inline-flex items-center rounded-lg bg-red-brand px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-red-brand-dark"
          >Get Early Access</a
        >
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-32">
    <!-- Background glow -->
    <div
      class="pointer-events-none absolute top-0 left-1/2 -translate-x-1/2 h-[600px] w-[800px] rounded-full bg-red-brand/8 blur-[120px]"
    >
    </div>

    <div class="relative mx-auto max-w-6xl px-6 text-center">
      <div
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-red-brand/20 bg-red-brand/5 px-4 py-1.5 text-sm text-red-brand-light"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-red-brand animate-pulse"></span>
        Coming Soon
      </div>

      <h1
        class="mx-auto max-w-4xl text-4xl font-bold leading-tight tracking-tight sm:text-6xl lg:text-7xl"
      >
        Turn every watch party into an
        <span
          class="bg-gradient-to-r from-red-brand to-red-brand-light bg-clip-text text-transparent"
          >unforgettable experience</span
        >
      </h1>

      <p
        class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-text-secondary sm:text-xl"
      >
        14+ interactive games built for NHL arenas and fan events. One app,
        two screens, hundreds of engaged fans.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="#contact"
          class="inline-flex items-center rounded-xl bg-red-brand px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-red-brand/25 transition-all hover:bg-red-brand-dark hover:shadow-red-brand/40 hover:-translate-y-0.5"
          >Request a Demo</a
        >
        <a
          href="#games"
          class="inline-flex items-center gap-2 rounded-xl border border-white/10 px-8 py-3.5 text-base font-medium text-text-secondary transition-colors hover:border-white/20 hover:text-text-primary"
          >See the Games ↓</a
        >
      </div>
    </div>
  </section>

  <!-- Dual-screen visual -->
  <section class="relative py-16 sm:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div
        class="relative rounded-2xl border border-white/5 bg-surface-raised p-4 sm:p-8"
      >
        <div class="grid gap-4 sm:grid-cols-2">
          <!-- Control window mock -->
          <div class="rounded-xl border border-white/10 bg-surface p-4">
            <div class="mb-3 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="h-3 w-3 rounded-full bg-red-500/60"></div>
                <div class="h-3 w-3 rounded-full bg-yellow-500/60"></div>
                <div class="h-3 w-3 rounded-full bg-green-500/60"></div>
              </div>
              <span class="text-xs text-text-muted">Control Window</span>
            </div>
            <div class="space-y-2">
              <div class="flex gap-2">
                <div class="w-1/4 space-y-2 rounded-lg bg-surface-overlay p-3">
                  <div class="h-2 w-full rounded bg-red-brand/30"></div>
                  <div class="h-2 w-3/4 rounded bg-white/5"></div>
                  <div class="h-2 w-full rounded bg-white/5"></div>
                  <div class="h-2 w-5/6 rounded bg-white/5"></div>
                  <div class="h-2 w-full rounded bg-white/5"></div>
                  <div class="h-2 w-2/3 rounded bg-white/5"></div>
                </div>
                <div class="flex-1 space-y-3 rounded-lg bg-surface-overlay p-3">
                  <div class="h-3 w-1/2 rounded bg-white/10"></div>
                  <div class="grid grid-cols-3 gap-2">
                    <div class="h-8 rounded bg-red-brand/20"></div>
                    <div class="h-8 rounded bg-white/5"></div>
                    <div class="h-8 rounded bg-white/5"></div>
                  </div>
                  <div class="h-20 rounded bg-white/5"></div>
                  <div class="flex gap-2">
                    <div class="h-8 flex-1 rounded bg-green-500/20"></div>
                    <div class="h-8 flex-1 rounded bg-white/5"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Display window mock -->
          <div class="rounded-xl border border-white/10 bg-surface p-4">
            <div class="mb-3 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="h-3 w-3 rounded-full bg-red-500/60"></div>
                <div class="h-3 w-3 rounded-full bg-yellow-500/60"></div>
                <div class="h-3 w-3 rounded-full bg-green-500/60"></div>
              </div>
              <span class="text-xs text-text-muted"
                >Display Window (TV / Projector)</span
              >
            </div>
            <div
              class="flex flex-col items-center justify-center rounded-lg bg-gradient-to-b from-surface-overlay to-surface p-6 text-center min-h-[180px]"
            >
              <div class="mb-3 text-4xl">🏒</div>
              <div class="text-2xl font-bold text-text-primary">
                LUCKY PUCK
              </div>
              <div class="mt-2 text-sm text-text-secondary">
                Drawing winner...
              </div>
              <div
                class="mt-4 h-2 w-3/4 overflow-hidden rounded-full bg-white/10"
              >
                <div
                  class="h-full w-2/3 rounded-full bg-gradient-to-r from-red-brand to-red-brand-light animate-pulse"
                >
                </div>
              </div>
            </div>
          </div>
        </div>
        <p class="mt-4 text-center text-sm text-text-muted">
          You control the games from your laptop. Fans see the action on the
          big screen.
        </p>
      </div>
    </div>
  </section>

  <!-- Games -->
  <section id="games" class="py-16 sm:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold sm:text-4xl">
          14+ games, one platform
        </h2>
        <p class="mt-4 text-text-secondary">
          From trivia to relay races, there's something for every crowd.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {games.map((game) => (
          <GameCard
            name={game.name}
            icon={game.icon}
            description={game.tagline}
            slug={game.slug}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Event Tools -->
  <section id="event-tools" class="py-16 sm:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold sm:text-4xl">
          Event tools that run the show
        </h2>
        <p class="mt-4 text-text-secondary">
          Presentation and utility modules that work alongside your games.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {modules.map((mod) => (
          <ModuleCard
            name={mod.name}
            icon={mod.icon}
            tagline={mod.tagline}
            slug={mod.slug}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="py-16 sm:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold sm:text-4xl">
          Simple to run, impossible to ignore
        </h2>
        <p class="mt-4 text-text-secondary">
          Set up in minutes. Run an entire season of events with ease.
        </p>
      </div>
      <div class="grid gap-12 sm:grid-cols-3">
        <StepCard
          step="1"
          title="Set Up Your Party"
          description="Import your team roster from the NHL API, pick your games, and configure your branding. Takes five minutes."
        />
        <StepCard
          step="2"
          title="Connect a Display"
          description="Plug in a TV or projector. The app auto-detects the second screen and goes fullscreen."
        />
        <StepCard
          step="3"
          title="Run the Show"
          description="Launch games from the control window. Fans see the action on the big screen in real time."
        />
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-16 sm:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold sm:text-4xl">Built for the big stage</h2>
        <p class="mt-4 text-text-secondary">
          Everything you need to run professional fan entertainment.
        </p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <FeatureItem
          icon="\u{1F3D2}"
          title="NHL API Integration"
          description="Auto-import current rosters and player headshots for all 32 NHL teams."
        />
        <FeatureItem
          icon="\u{1F3A8}"
          title="Team Branding"
          description="Automatic color theming with your team's official colors. Light and dark modes included."
        />
        <FeatureItem
          icon="\u{1F579}\uFE0F"
          title="Stream Deck Support"
          description="Control games with physical buttons via Elgato Stream Deck integration."
        />
        <FeatureItem
          icon="\u{1F4F1}"
          title="Dual-Screen Architecture"
          description="Separate control and display windows. Run the show from your laptop while fans watch the big screen."
        />
        <FeatureItem
          icon="\u{1F4C4}"
          title="PDF Generation"
          description="Auto-generate bingo cards, prediction sheets, and printable game materials."
        />
        <FeatureItem
          icon="\u{1F512}"
          title="Party Isolation"
          description="Each watch party gets its own config, roster, and game state. Run a whole season without conflicts."
        />
      </div>
    </div>
  </section>

  <!-- Social proof -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <div
        class="rounded-2xl border border-white/5 bg-surface-raised p-8 sm:p-12"
      >
        <p class="text-lg leading-relaxed text-text-secondary sm:text-xl">
          Battle-tested at NHL watch parties with hundreds of fans per event
          across a full season. Built by people who actually run the show.
        </p>
        <div class="mt-6 text-sm text-text-muted">
          Designed for arena entertainment teams
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-16 sm:py-24">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="text-3xl font-bold sm:text-4xl">
        Ready to level up your watch parties?
      </h2>
      <p class="mt-4 text-text-secondary">
        We're gearing up for wider release. Get in touch to schedule a demo
        or get early access for your team.
      </p>
      <div class="mt-8">
        <a
          href="mailto:hello@watchparty.app"
          class="inline-flex items-center rounded-xl bg-red-brand px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-red-brand/25 transition-all hover:bg-red-brand-dark hover:shadow-red-brand/40 hover:-translate-y-0.5"
          >Get in Touch</a
        >
      </div>
      <p class="mt-4 text-sm text-text-muted">
        hello@watchparty.app
      </p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-white/5 py-8">
    <div
      class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 sm:flex-row"
    >
      <span class="text-sm text-text-muted"
        >&copy; {new Date().getFullYear()} Watch Party Games</span
      >
      <span class="text-sm text-text-muted">watchparty.app</span>
    </div>
  </footer>
</Layout>
